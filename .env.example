# Svet za malo Astro frontend
# Copy to .env for local development. Configure the same values in Vercel for production.

# Public site URL used for canonical URLs, Open Graph URLs and sitemap generation.
SITE_URL=https://svetzamalo.cz
PUBLIC_SITE_URL=https://svetzamalo.cz

# Strapi API base URL. In production this must point to Strapi Cloud / production Strapi.
STRAPI_URL=http://localhost:1337

# Optional. Only needed if public Strapi endpoints are protected by an API token.
STRAPI_API_TOKEN=
