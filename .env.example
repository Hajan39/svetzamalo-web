# ============================================================================
# LOWCOST TRAVELING - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.local and fill in your actual values

# ============================================================================
# SITE CONFIGURATION
# ============================================================================
VITE_SITE_URL=https://lowcost-traveling.com

# ============================================================================
# ANALYTICS & TRACKING (GA4)
# ============================================================================
# Enable analytics (set to 'true' to enable)
VITE_ENABLE_ANALYTICS=true

# Analytics provider ('google-analytics', 'plausible', 'none')
VITE_ANALYTICS_PROVIDER=google-analytics

# Google Analytics 4
VITE_GA_TRACKING_ID=GA-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Alternative: Plausible Analytics (privacy-focused)
VITE_PLAUSIBLE_DOMAIN=yourdomain.com

# Debug analytics in development
VITE_SHOW_ANALYTICS_DEBUGGER=true

# ============================================================================
# MONETIZATION & ADS
# ============================================================================
# Enable ads (set to 'true' to enable)
VITE_ENABLE_ADS=true

# Ad provider ('adsense', 'none')
VITE_AD_PROVIDER=adsense

# Google AdSense
VITE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# ============================================================================
# AFFILIATE NETWORKS
# ============================================================================
# CJ.com (Commission Junction) - for Booking.com and others
VITE_CJ_PID=your_cj_publisher_id
VITE_CJ_BOOKING_AID=booking_advertiser_id

# Skyscanner
VITE_SKYSCANNER_AFFILIATE_ID=your_skyscanner_id

# GetYourGuide
VITE_GETYOURGUIDE_PARTNER_ID=your_gyg_partner_id

# Hostelworld
VITE_HOSTELWORLD_AFFILIATE_ID=your_hostelworld_id

# ============================================================================
# BOOK PAGE (/book) – sell on site
# ============================================================================
# Checkout URL: Stripe Payment Link (recommended) or any shop. After payment, set success URL to https://yoursite.com/book/success
VITE_BOOK_BUY_URL=
# Display price next to Buy button (e.g. "299 Kč", "€9.99")
VITE_BOOK_PRICE=
# Direct URL to free ebook PDF (after email signup). Leave empty to only collect emails.
VITE_EBOOK_PDF_URL=

# ============================================================================
# CONTENT MANAGEMENT (Future use)
# ============================================================================
# CMS integration
CMS_URL=https://your-cms.com/api
CMS_API_KEY=your_cms_api_key

# Database integration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================================================
# CDN & ASSETS (Vercel deployment)
# ============================================================================
VITE_CDN_URL=https://your-cdn.com

# ============================================================================
# DEVELOPMENT
# ============================================================================
# Enable mock data for development
VITE_ENABLE_MOCK_DATA=false

# Logging level ('error', 'warn', 'info', 'debug')
VITE_LOG_LEVEL=info

# ============================================================================
# DEPLOYMENT
# ============================================================================
# Vercel-specific
VERCEL_URL=your-vercel-url.vercel.app
VERCEL_ENV=production

# ============================================================================
# SECURITY (Optional)
# ============================================================================
# API keys for external services
# VITE_API_KEY=your_api_key
# VITE_SECRET_KEY=your_secret_key