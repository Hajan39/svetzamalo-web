# Svet za malo Astro frontend
# Copy to .env for local development. Configure the same values in Vercel for production.

# Public site URL used for canonical URLs, Open Graph URLs and sitemap generation.
SITE_URL=https://svetzamalo.cz
PUBLIC_SITE_URL=https://svetzamalo.cz

# Content routing mode:
# - sanity (default): Sanity primary for editorial reads, Strapi fallback
# - strapi: Strapi only
PUBLIC_CONTENT_SOURCE=sanity

# Sanity content source (editorial reads)
PUBLIC_SANITY_PROJECT_ID=bh335dwp
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2025-01-01

# Optional read token for private datasets
PUBLIC_SANITY_READ_TOKEN=
# Optional server token for Sanity (when needed for non-public reads)
SANITY_API_TOKEN=

# Strapi API base URL. In production this must point to Strapi Cloud / production Strapi.
STRAPI_URL=http://localhost:1337

# Optional. Needed if Strapi endpoints (including fallback reads / site config / orders) are protected.
STRAPI_API_TOKEN=
