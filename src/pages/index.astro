---
import { Image } from 'astro:assets';
import ArticleCard from '@/components/article/ArticleCard.astro';
import DestinationCard from '@/components/destination/DestinationCard.astro';
import LeadCapture from '@/components/marketing/LeadCapture.astro';
import Layout from '@/layouts/Layout.astro';
import { getFreeEbookDescription, getFreeEbookTitle, getPaidBookTitle, isFreeEbookEnabled, isPaidEbookEnabled } from '@/lib/bookConfig';
import { getContinentLabel } from '@/lib/continentLabels';
import { fetchArticlesPage, fetchDestinations, fetchLatestArticles, fetchSiteConfig } from '@/lib/content/api';
import { translations } from '@/i18n/translations';
import { getLocaleFromAstro, withLocalePath } from '@/lib/i18n';
import { getDraftModeProps } from '@/lib/sanity/draftMode';

export const prerender = false;

const locale = getLocaleFromAstro(Astro);
const sanityOptions = getDraftModeProps(Astro.cookies);

let [articles, articlePage, destinations, siteConfig] = await Promise.all([
	fetchLatestArticles(9, locale, sanityOptions),
	fetchArticlesPage(1, locale, undefined, sanityOptions),
	fetchDestinations(locale, sanityOptions),
	fetchSiteConfig(locale),
]);
if (locale === 'en' && articles.length === 0 && destinations.length === 0) {
	[articles, articlePage, destinations, siteConfig] = await Promise.all([
		fetchLatestArticles(9, 'cs', sanityOptions),
		fetchArticlesPage(1, 'cs', undefined, sanityOptions),
		fetchDestinations('cs', sanityOptions),
		fetchSiteConfig('cs'),
	]);
}
const freeEbookAvailable = isFreeEbookEnabled(siteConfig);
const paidEbookAvailable = isPaidEbookEnabled(siteConfig);
const freeEbookTitle = getFreeEbookTitle(siteConfig);
const freeEbookDescription = getFreeEbookDescription(siteConfig);
const paidBookTitle = getPaidBookTitle(siteConfig);
const featuredArticle = articles[0];
const secondaryArticles = articles.slice(1, 4);
const latestArticles = articles.slice(4, 9);
const featuredDestinations = destinations.slice(0, 6);
const destinationCount = destinations.length;
const articleCount = articlePage.total || articles.length;
const text = translations[locale].pages.home;
const shared = translations[locale].shared;

const continentLabels = new Intl.ListFormat(shared.htmlLocale, { style: 'long', type: 'conjunction' }).format(
	Array.from(new Set(destinations.map((destination) => getContinentLabel(destination.continent, locale))))
		.slice(0, 3),
);
---

<Layout
	title={text.title}
	description={text.description}
	siteConfig={siteConfig}
>
	<section class="home-hero">
		<div class="home-hero-media" aria-hidden="true"></div>
		<div class="home-hero-overlay"></div>
		<div class="container-wide home-hero-inner">
			<div class="home-hero-copy">
				<p class="section-kicker">{text.kicker}</p>
				<h1>{text.heroHeading}</h1>
				<p>{text.heroBody}</p>
				<div class="hero-actions">
					<a class="btn-primary" href={withLocalePath('/destinations', locale)}>{text.chooseDestination}</a>
					<a class="btn-secondary" href={withLocalePath('/articles', locale)}>{text.readArticles}</a>
				</div>
			</div>

			<div class="home-hero-panel" aria-label={text.quickOverview}>
				<div>
					<span>{destinationCount || '27'}+</span>
					<p>{text.destinationCountLabel}</p>
				</div>
				<div>
					<span>{articleCount || '300'}+</span>
					<p>{text.articleCountLabel}</p>
				</div>
				<div>
					<span>{text.free}</span>
					<p>{freeEbookTitle}</p>
				</div>
			</div>
		</div>
	</section>

	<section class="home-intro-band">
		<div class="container-wide home-intro-grid">
			<div>
				<p class="section-kicker">{text.introKicker}</p>
				<h2>{text.introHeading}</h2>
				<p>{text.introBody}</p>
			</div>
			<ul class="home-proof-list">
				<li><strong>{text.proof1Title}</strong><span>{text.proof1Text}</span></li>
				<li><strong>{text.proof2Title}</strong><span>{text.proof2Text}</span></li>
				<li><strong>{text.proof3Title}</strong><span>{text.proof3Text}</span></li>
			</ul>
		</div>
	</section>

	{featuredArticle && (
		<section class="container-wide featured-grid-section">
			<div class="section-heading-row">
				<div>
					<p class="section-kicker">{text.featuredKicker}</p>
					<h2>{text.featuredHeading}</h2>
				</div>
				<a href={withLocalePath('/articles', locale)} class="text-link">{text.allArticles}</a>
			</div>

			<div class="featured-content-grid">
				<a href={withLocalePath(`/articles/${featuredArticle.slug}`, locale)} class="featured-article">
					{featuredArticle.coverImage ? (
						<Image src={featuredArticle.coverImage.src} alt={featuredArticle.coverImage.alt || featuredArticle.title} width={900} height={506} loading="eager" />
					) : (
						<div class="featured-article-fallback">{featuredArticle.title}</div>
					)}
					<div class="featured-article-copy">
						<p class="section-kicker">{text.newArticle}</p>
						<h3>{featuredArticle.title}</h3>
						<p>{featuredArticle.intro}</p>
						<span>{text.readGuide}</span>
					</div>
				</a>

				<div class="side-article-list">
					{secondaryArticles.map((article) => (
						<a href={withLocalePath(`/articles/${article.slug}`, locale)} class="side-article">
							<span>{article.countryName || article.articleType?.replace(/-/g, ' ') || shared.guideFallback}</span>
							<strong>{article.title}</strong>
						</a>
					))}
				</div>
			</div>
		</section>
	)}

	{freeEbookAvailable && (
		<div class="container-wide soft-cta-wrap">
			<LeadCapture
				source="home_midpage"
				kicker={text.freeMaterial}
				title={text.getFreeEbook(freeEbookTitle)}
				text={freeEbookDescription}
				buttonLabel={text.getFreeEbookButton}
			/>
		</div>
	)}

	<section class="container-wide destinations-preview-section">
		<div class="section-heading-row">
			<div>
				<p class="section-kicker">{text.destinationsKicker}</p>
				<h2>{text.destinationsHeading}</h2>
				{continentLabels && <p>{text.destinationsIntro(continentLabels)}</p>}
			</div>
			<a href={withLocalePath('/destinations', locale)} class="text-link">{text.browseDestinations}</a>
		</div>

		{featuredDestinations.length === 0 ? (
			<div class="empty-state">{text.emptyDestinations}</div>
		) : (
			<div class="destination-preview-grid">
				{featuredDestinations.map((destination) => <DestinationCard destination={destination} />)}
			</div>
		)}
	</section>

	<section class="content-paths-band">
		<div class="container-wide content-paths-grid">
			<div>
				<p class="section-kicker">{text.usageKicker}</p>
				<h2>{text.usageHeading}</h2>
			</div>
			<a href={withLocalePath('/articles', locale) + '?q=itinerar'} class="content-path">
				<span>01</span>
				<strong>{text.path1Title}</strong>
				<p>{text.path1Text}</p>
			</a>
			<a href={withLocalePath('/articles', locale) + '?q=low-cost'} class="content-path">
				<span>02</span>
				<strong>{text.path2Title}</strong>
				<p>{text.path2Text}</p>
			</a>
			<a href={withLocalePath('/articles', locale) + '?q=prakticky'} class="content-path">
				<span>03</span>
				<strong>{text.path3Title}</strong>
				<p>{text.path3Text}</p>
			</a>
		</div>
	</section>

	<section class="container-wide latest-section">
		<div class="section-heading-row">
			<div>
				<p class="section-kicker">{text.newsKicker}</p>
				<h2>{text.newsHeading}</h2>
			</div>
			{paidEbookAvailable ? <a class="btn-secondary" href={withLocalePath('/book', locale)}>{paidBookTitle}</a> : <a class="text-link" href={withLocalePath('/articles', locale)}>{text.articleArchive}</a>}
		</div>

		{articles.length === 0 ? (
			<div class="empty-state">{text.emptyArticles}</div>
		) : (
			<div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3 md:gap-8">
				{(latestArticles.length ? latestArticles : articles).map((article) => <ArticleCard article={article} variant="block" />)}
			</div>
		)}
	</section>

	{freeEbookAvailable && (
		<div class="container-wide soft-cta-wrap soft-cta-wrap-bottom">
			<LeadCapture
				source="home_bottom"
				compact
				kicker={text.freeMaterial}
				title={text.sendFreeEbookTitle(freeEbookTitle)}
				text={freeEbookDescription}
				buttonLabel={text.sendChecklist}
			/>
		</div>
	)}
</Layout>
