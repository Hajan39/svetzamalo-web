---
import Layout from '@/layouts/Layout.astro';
import { fetchPageCopy } from '@/lib/content/api';
import { copyValue } from '@/lib/copy';
import { translations } from '@/i18n/translations';
import { getLangFromUrl, withLocalePath } from '@/i18n/utils';

const locale = getLangFromUrl(Astro.url);
const token = Astro.url.searchParams.get('token') || '';
const downloadType = Astro.url.searchParams.get('type') || 'free';
const isPaidDownload = downloadType === 'paid';
const copy = await fetchPageCopy(isPaidDownload ? 'ebook-download-paid' : 'ebook-download-free', locale);
const apiDownloadUrl = token ? `/api/ebook/download?token=${encodeURIComponent(token)}` : '';
const copyVariables = { type: downloadType };
const text = translations[locale].pages.ebookDownload;

const title = copyValue(copy?.metaTitle, isPaidDownload ? text.titlePaid : text.titleFree, copyVariables);
const description = copyValue(copy?.metaDescription, isPaidDownload
  ? text.descriptionPaid
  : text.descriptionFree, copyVariables);
---

<Layout title={title} description={description} canonicalPath={withLocalePath('/ebook/download', locale)}>
  <section class="container-narrow py-10 md:py-16">
    <div class="brand-card px-6 py-7 sm:px-8 sm:py-8">
      <h1 class="mb-4">{copyValue(copy?.heading, isPaidDownload ? text.headingPaid : text.headingFree, copyVariables)}</h1>
      {token ? (
        <>
          {isPaidDownload ? (
            <>
              <p class="mb-4">{copyValue(copy?.intro, text.paidIntro, copyVariables)}</p>
              <p class="mb-6 text-foreground-secondary">{copyValue(copy?.body, text.paidBody, copyVariables)}</p>
            </>
          ) : (
            <p class="mb-6">{copyValue(copy?.intro, text.freeIntro, copyVariables)}</p>
          )}
          <button class="btn-primary" type="button" data-download-button data-download-url={apiDownloadUrl}>
            {copyValue(copy?.primaryButtonLabel, isPaidDownload ? text.downloadPaid : text.downloadFree, copyVariables)}
          </button>
          <p
            class="mt-4 text-sm text-foreground-secondary"
            data-download-status
            data-loading-message={copyValue(copy?.successMessage, text.loading, copyVariables)}
            data-error-message={copyValue(copy?.errorMessage, text.error, copyVariables)}
            data-ready-message={text.redirectReady}
            data-ready-timed-template={text.redirectReadyTimed(999).replace('999', '{seconds}')}
            data-fallback-loading={text.fallbackLoading}
            data-fallback-error={text.fallbackError}
            aria-live="polite"
          ></p>
        </>
      ) : isPaidDownload ? (
        <>
          <p class="mb-6">{copyValue(copy?.secondaryBody, text.missingPaid, copyVariables)}</p>
          <a class="btn-secondary" href={withLocalePath('/book', locale)}>{copyValue(copy?.secondaryButtonLabel, text.backToBook, copyVariables)}</a>
        </>
      ) : (
        <>
          <p class="mb-6">{copyValue(copy?.secondaryBody, text.missingFree, copyVariables)}</p>
          <form class="flex flex-col gap-3 sm:flex-row" method="post" action="/api/leads">
            <input type="hidden" name="leadType" value="ebook" />
            <input type="hidden" name="source" value="ebook-download" />
            <input class="form-field" type="email" name="email" placeholder={text.emailPlaceholder} required />
            <button class="btn-primary" type="submit">{copyValue(copy?.secondaryButtonLabel, text.sendNew, copyVariables)}</button>
          </form>
        </>
      )}
    </div>
  </section>
  {token && (
    <script>
      const button = document.querySelector('[data-download-button]');
      const status = document.querySelector('[data-download-status]');

      button?.addEventListener('click', async () => {
        const downloadUrl = button.getAttribute('data-download-url');
        if (!downloadUrl) return;

        button.setAttribute('disabled', 'true');
        if (status) status.textContent = status.getAttribute('data-loading-message') || status.getAttribute('data-fallback-loading') || '';

        try {
          const response = await fetch(downloadUrl, { headers: { accept: 'application/json' } });
          const payload = await response.json().catch(() => null);

          if (!response.ok || !payload?.url) {
            throw new Error('download_failed');
          }

          if (status) {
            const readyMessage = status.getAttribute('data-ready-message') || '';
            const readyTimedTemplate = status.getAttribute('data-ready-timed-template') || '{seconds}';
            status.textContent = payload.expiresInSeconds
              ? readyTimedTemplate.replace('{seconds}', String(payload.expiresInSeconds))
              : readyMessage;
          }

          window.location.href = payload.url;
        } catch {
          if (status) status.textContent = status.getAttribute('data-error-message') || status.getAttribute('data-fallback-error') || '';
          button.removeAttribute('disabled');
        }
      });
    </script>
  )}
</Layout>
