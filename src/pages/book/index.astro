---
import Layout from '@/layouts/Layout.astro';
import { getFreeEbookDescription, getFreeEbookTitle, getPaidBookDescription, getPaidBookTitle, isFreeEbookEnabled, isPaidEbookEnabled } from '@/lib/bookConfig';
import { fetchSiteConfig } from '@/lib/content/api';
import { translations } from '@/i18n/translations';
import { getLangFromUrl, withLocalePath } from '@/i18n/utils';

export const prerender = false;

const locale = getLangFromUrl(Astro.url);
let siteConfig = await fetchSiteConfig(locale);
if (locale === 'en' && !siteConfig) {
  siteConfig = await fetchSiteConfig('cs');
}
const price = siteConfig?.bookPrice || siteConfig?.bookBankAmount || '490 Kč';
const freeEbookAvailable = isFreeEbookEnabled(siteConfig);
const bankEnabled = isPaidEbookEnabled(siteConfig);
const freeEbookTitle = getFreeEbookTitle(siteConfig);
const freeEbookDescription = getFreeEbookDescription(siteConfig);
const paidBookTitle = getPaidBookTitle(siteConfig);
const paidBookDescription = getPaidBookDescription(siteConfig);
const text = translations[locale].pages.book;

const bookPageTitle = `${freeEbookTitle} ${text.titleJoin} ${paidBookTitle} | ${translations[locale].shared.brand}`;
---

<Layout title={bookPageTitle} description={`${freeEbookDescription} ${paidBookDescription}`} canonicalPath={withLocalePath('/book', locale)} siteConfig={siteConfig}>
  <section class="book-hero">
    <div class="container-wide book-hero-grid">
      <div>
        <p class="section-kicker">{text.travelMaterials}</p>
        <h1>{freeEbookTitle}</h1>
        <p>{freeEbookDescription}</p>
        <div class="hero-actions">
          {freeEbookAvailable ? (
            <>
              <a href="#ebook-zdarma" class="btn-primary">{text.downloadFree}</a>
              <a href={withLocalePath('/articles', locale)} class="btn-secondary">{text.browseArticles}</a>
            </>
          ) : (
            <a href={withLocalePath('/articles', locale)} class="btn-primary">{text.browseArticles}</a>
          )}
        </div>
      </div>
      <aside class="book-summary" aria-label={text.summaryLabel}>
        {siteConfig?.freeEbookCover ? (
          <img src={siteConfig.freeEbookCover.src} alt={siteConfig.freeEbookCover.alt || freeEbookTitle} loading="eager" decoding="async" />
        ) : (
          <>
            <span>{text.insideYouGet}</span>
            <ul>
              <li>{text.pickDestination}</li>
              <li>{text.avoidMistakes}</li>
              <li>{text.checklist}</li>
            </ul>
          </>
        )}
      </aside>
    </div>
  </section>

  <section class="container-wide book-options-section" id="ebook-zdarma">
    <div class="section-heading-row">
      <div>
        <p class="section-kicker">{text.chooseByStage}</p>
        <h2>{text.valueFirst}</h2>
      </div>
      <p>{text.valueBody}</p>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      <section class="brand-card book-option book-option-primary">
        <p class="section-kicker">{text.goodStart}</p>
        {siteConfig?.freeEbookCover && <img class="book-option-media" src={siteConfig.freeEbookCover.src} alt={siteConfig.freeEbookCover.alt || freeEbookTitle} loading="lazy" decoding="async" />}
        <h3>{freeEbookTitle}</h3>
        <p>{freeEbookDescription}</p>
        {freeEbookAvailable ? (
          <form class="space-y-3" method="post" action="/api/leads">
            <input type="hidden" name="leadType" value="ebook" />
            <input type="hidden" name="source" value="book" />
            <label class="sr-only" for="free-ebook-email">{text.freeEmailLabel}</label>
            <input id="free-ebook-email" class="form-field" type="email" name="email" placeholder={text.freeEmailPlaceholder} required />
            <button class="btn-primary w-full" type="submit">{text.sendFree}</button>
            <p class="lead-note">{text.freeNote}</p>
          </form>
        ) : (
          <p class="text-sm text-foreground-muted">{text.freeUnavailable}</p>
        )}
      </section>

      <section class="brand-card book-option">
        <p class="section-kicker">{text.wantMore}</p>
        {siteConfig?.bookCover && <img class="book-option-media" src={siteConfig.bookCover.src} alt={siteConfig.bookCover.alt || paidBookTitle} loading="lazy" decoding="async" />}
        <h3>{paidBookTitle}</h3>
        <p>{paidBookDescription} {text.priceLabel}: <strong>{price}</strong>.</p>
        {bankEnabled ? (
          <form class="space-y-3" method="post" action="/api/orders">
            <input type="hidden" name="productCode" value="ebook-paid-v1" />
            <label class="sr-only" for="paid-book-name">{text.fullNameLabel}</label>
            <input id="paid-book-name" class="form-field" type="text" name="fullName" placeholder={text.fullNamePlaceholder} required />
            <label class="sr-only" for="paid-book-email">{text.deliveryEmailLabel}</label>
            <input id="paid-book-email" class="form-field" type="email" name="email" placeholder={text.deliveryEmailPlaceholder} required />
            <button class="btn-primary w-full" type="submit">{text.orderByBank}</button>
          </form>
        ) : (
          <p class="text-sm text-foreground-muted">{text.ordersSoon}</p>
        )}
      </section>
    </div>
  </section>
</Layout>
