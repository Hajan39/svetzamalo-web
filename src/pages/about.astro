---
import Layout from '@/layouts/Layout.astro';
import { fetchSiteConfig } from '@/lib/content/api';
import { getLocaleFromAstro, withLocalePath } from '@/lib/i18n';
import { translations } from '@/i18n/translations';

export const prerender = false;

const locale = getLocaleFromAstro(Astro);
const siteConfig = await fetchSiteConfig(locale);
const siteEmail = siteConfig?.siteEmail || 'info@svetzamalo.cz';

const about = translations[locale].pages.about;

const text = about;
const principles = about.principles;
const stats = about.stats;
const talks = about.talksList;
const topics = about.topics;
const pastEvents = about.pastEvents;
const upcomingTalks = about.upcomingTalks;
const talkSubject = encodeURIComponent(about.requestTalkSubject);
---

<Layout title={text.title} description={text.description} canonicalPath={withLocalePath('/about', locale)} siteConfig={siteConfig}>
  <section class="about-hero">
    <div class="container-wide about-hero-grid">
      <div class="about-hero-copy">
        <p class="section-kicker">{text.who}</p>
        <h1>{text.heroHeading}</h1>
        <p>{text.heroBody}</p>
        <div class="hero-actions">
          <a class="btn-primary" href={withLocalePath('/destinations', locale)}>{text.browseDestinations}</a>
          <a class="btn-secondary" href={`mailto:${siteEmail}`}>{text.writeUs}</a>
        </div>
      </div>

      <div class="about-proof-panel" aria-label={text.quickFacts}>
        {stats.map((stat) => (
          <div>
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="about-story-band">
    <div class="container-wide about-story-grid">
      <div>
        <p class="section-kicker">{text.approach}</p>
        <h2>{text.approachHeading}</h2>
      </div>
      <div class="about-story-copy">
        <p>{text.approachP1}</p>
        <p>{text.approachP2}</p>
      </div>
    </div>
  </section>

  <section class="container-wide about-principles-section">
    <div class="about-principles-grid">
      {principles.map((principle) => (
        <article class="about-principle">
          <h2>{principle.title}</h2>
          <p>{principle.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="about-talks-band">
    <div class="container-wide about-talks-grid">
      <div>
        <p class="section-kicker">{text.talks}</p>
        <h2>{text.talksHeading}</h2>
        <p>{text.talksBody}</p>
        <ul class="about-check-list">
          {talks.map((talk) => <li>{talk}</li>)}
        </ul>
        <a class="btn-primary" href={`mailto:${siteEmail}?subject=${talkSubject}`}>{text.requestTalk}</a>
      </div>

      <div class="about-topic-panel">
        <h3>{text.topicsWeCanCover}</h3>
        <div class="about-topic-grid">
          {topics.map((topic) => <span>{topic}</span>)}
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide about-events-section">
    <div class="section-heading-row">
      <div>
        <p class="section-kicker">{text.whereSeen}</p>
        <h2>{text.eventsHeading}</h2>
      </div>
      <a class="text-link" href={`mailto:${siteEmail}`}>{text.collab}</a>
    </div>

    <div class="about-events-grid">
      <div class="about-events-list">
        {pastEvents.map((event) => (
          <a href={event.url} target="_blank" rel="noopener noreferrer" class="about-event-row">
            <span>{event.date}</span>
            <strong>{event.title}</strong>
            <small>{event.place}</small>
          </a>
        ))}
      </div>

      <aside class="about-upcoming-panel">
        <h3>{text.upcoming}</h3>
        <ul>
          {upcomingTalks.map((talk) => (
            <li>
              <strong>{talk.title}</strong>
              <span>{talk.meta}</span>
            </li>
          ))}
        </ul>
        <p>{text.upcomingNote}</p>
      </aside>
    </div>
  </section>

  <section class="container-wide about-contact-section">
    <div>
      <p class="section-kicker">{text.contact}</p>
      <h2>{text.contactHeading}</h2>
      <p>{text.contactBody}</p>
    </div>
    <a class="btn-primary" href={`mailto:${siteEmail}`}>{siteEmail}</a>
  </section>
</Layout>
