---
/**
 * Live destination info strip — always rendered, client-side JS scans the
 * page text for currency code, timezone (UTC±H), driving side and socket type badges.
 *  - Exchange rate to the user's preferred header currency (Frankfurter, no auth)
 *  - Current local time (Intl.DateTimeFormat, IANA or UTC±H)
 *  - Electric socket type badges with hover SVG tooltip
 */
---

<!-- Always mount the bar; JS will show/hide items after DOM scan -->
<div
  id="dest-live"
  class="mb-5 hidden flex-wrap items-center gap-x-5 gap-y-2.5 rounded-xl border border-border bg-background-secondary px-5 py-3.5 text-sm sm:mb-6"
>
  <!-- Currency -->
  <div id="live-currency-wrap" class="hidden items-center gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="shrink-0 text-primary" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/>
      <path d="M16 8h-6a2 2 0 0 0 0 4h4a2 2 0 0 1 0 4H8"/>
      <path d="M12 18V6"/>
    </svg>
    <span class="text-foreground-secondary">1&nbsp;<strong id="live-currency-code" class="font-semibold text-foreground"></strong></span>
    <span id="live-exrate" class="font-semibold tabular-nums text-primary" aria-live="polite">…</span>
  </div>

  <span id="live-sep-tz" class="hidden text-border" aria-hidden="true">·</span>

  <!-- Clock -->
  <div id="live-clock-wrap" class="hidden items-center gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="shrink-0 text-primary" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/>
      <polyline points="12 6 12 12 16 14"/>
    </svg>
    <span id="live-clock" class="font-semibold tabular-nums text-foreground" aria-live="polite">--:--</span>
    <span class="text-foreground-secondary">místní čas</span>
  </div>

  <span id="live-sep-driving" class="hidden text-border" aria-hidden="true">·</span>

  <!-- Driving side -->
  <div id="live-driving" class="hidden items-center gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="shrink-0 text-primary" aria-hidden="true">
      <path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.6-1.9L18 10l-2-4H8l-2 4-2.4 1.1C2.7 11.3 2 12.1 2 13v3c0 .6.4 1 1 1h2"/>
      <circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/>
    </svg>
    <span class="text-foreground-secondary">Jezdí se</span>
    <span id="live-driving-side" class="font-semibold text-foreground"></span>
  </div>

  <span id="live-sep-socket" class="hidden text-border" aria-hidden="true">·</span>

  <!-- Sockets -->
  <div id="live-socket" class="hidden items-center gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="shrink-0 text-primary" aria-hidden="true">
      <path d="M5 11h14"/><path d="M8 11V7m8 4V7"/>
      <path d="M5 11a7 7 0 0 0 14 0"/><path d="M12 18v3"/>
    </svg>
    <span class="text-foreground-secondary">Zásuvky</span>
    <span id="live-socket-tags" class="ml-1 flex flex-wrap gap-1"></span>
  </div>
</div>

<!-- Socket tooltip (position:fixed, injected near cursor) -->
<div
  id="socket-tip"
  style="display:none;position:fixed;z-index:300;"
  class="pointer-events-none flex-col items-center gap-1.5 rounded-xl border border-border bg-white p-3 shadow-xl"
  role="tooltip"
  aria-hidden="true"
>
  <svg id="socket-tip-svg" xmlns="http://www.w3.org/2000/svg" width="60" height="80" viewBox="0 0 60 80" class="mx-auto block"></svg>
  <p id="socket-tip-label" class="mt-1 max-w-[180px] text-center text-xs leading-snug text-foreground-secondary"></p>
</div>

<script>
(function destLive() {
  /* ── Socket SVG definitions (must be first — used in filter below) ── */
  const BASE = `<rect x="3" y="3" width="54" height="74" rx="6" fill="#f9fafb" stroke="#d1d5db" stroke-width="2"/>`;
  const SOCKETS: Record<string, { label: string; svgInner: string }> = {
    A: { label: 'Typ A — USA, Japonsko (110 V, 2 ploché kolíky)', svgInner: BASE + `<rect x="18" y="20" width="9" height="27" rx="2.5" fill="#374151"/><rect x="33" y="20" width="9" height="27" rx="2.5" fill="#374151"/>` },
    B: { label: 'Typ B — USA, Kanada (110 V, 2 ploché + kulatý zem.)', svgInner: BASE + `<rect x="18" y="16" width="9" height="23" rx="2.5" fill="#374151"/><rect x="33" y="16" width="9" height="23" rx="2.5" fill="#374151"/><circle cx="30" cy="53" r="6" fill="#374151"/>` },
    C: { label: 'Typ C — Evropa, Asie, Jižní Amerika (230 V, 2 kulaté)', svgInner: BASE + `<circle cx="20" cy="38" r="7" fill="#374151"/><circle cx="40" cy="38" r="7" fill="#374151"/>` },
    E: { label: 'Typ E — Francie, Belgie, Polsko (2 kulaté + kolík)', svgInner: BASE + `<circle cx="20" cy="33" r="7" fill="#374151"/><circle cx="40" cy="33" r="7" fill="#374151"/><circle cx="30" cy="57" r="4" fill="#9ca3af"/>` },
    F: { label: 'Typ F / Schuko — Německo, Střední Evropa (2 kulaté + boční zemnicí)', svgInner: BASE + `<circle cx="20" cy="36" r="7" fill="#374151"/><circle cx="40" cy="36" r="7" fill="#374151"/><rect x="3" y="29" width="9" height="14" rx="2" fill="#9ca3af"/><rect x="48" y="29" width="9" height="14" rx="2" fill="#9ca3af"/>` },
    G: { label: 'Typ G — Velká Británie, Hong Kong, Singapur (3 pravoúhlé)', svgInner: BASE + `<rect x="9" y="21" width="14" height="7" rx="2" fill="#374151" transform="rotate(-45 16 24.5)"/><rect x="37" y="21" width="14" height="7" rx="2" fill="#374151" transform="rotate(45 44 24.5)"/><rect x="23" y="44" width="14" height="8" rx="2" fill="#374151"/>` },
    I: { label: 'Typ I — Austrálie, Čína, Argentina (šikmé ploché kolíky)', svgInner: BASE + `<rect x="16" y="26" width="14" height="7" rx="2" fill="#374151" transform="rotate(30 23 29.5)"/><rect x="30" y="26" width="14" height="7" rx="2" fill="#374151" transform="rotate(-30 37 29.5)"/><circle cx="30" cy="53" r="5" fill="#374151"/>` },
    K: { label: 'Typ K — Dánsko (2 kulaté + podkova)', svgInner: BASE + `<circle cx="20" cy="33" r="7" fill="#374151"/><circle cx="40" cy="33" r="7" fill="#374151"/><path d="M24 55 Q30 46 36 55" stroke="#374151" stroke-width="4.5" fill="none" stroke-linecap="round"/>` },
    L: { label: 'Typ L — Itálie (3 kulaté v řadě)', svgInner: BASE + `<circle cx="14" cy="40" r="5.5" fill="#374151"/><circle cx="30" cy="40" r="5.5" fill="#374151"/><circle cx="46" cy="40" r="5.5" fill="#374151"/>` },
    M: { label: 'Typ M — Jižní Afrika (3 velké kulaté)', svgInner: BASE + `<circle cx="30" cy="22" r="7" fill="#374151"/><circle cx="16" cy="49" r="7" fill="#374151"/><circle cx="44" cy="49" r="7" fill="#374151"/>` },
    N: { label: 'Typ N — Brazílie (2 kulaté + kulatý zem.)', svgInner: BASE + `<circle cx="20" cy="32" r="6.5" fill="#374151"/><circle cx="40" cy="32" r="6.5" fill="#374151"/><circle cx="30" cy="54" r="5.5" fill="#374151"/>` },
  };

  /* ── Collect all visible text from chapter cards ────── */
  const allNodes = Array.from(
    document.querySelectorAll<HTMLElement>('main .prose-content p, main .prose-content li')
  );
  const pageText = allNodes.map(n => n.textContent ?? '').join('\n');

  /* ── Extract currency code ─────────────────────────── */
  // Looks for patterns like "Měna: Americký dolar (USD)" or "Měna: USD"
  const currencyMatch =
    pageText.match(/[Mm]ěna\s*:\s*[^(\n]+\(([A-Z]{3})\)/) ??
    pageText.match(/[Mm]ěna\s*:\s*([A-Z]{3})\b/);
  const currencyCode = currencyMatch?.[1] ?? null;

  /* ── Extract timezone ──────────────────────────────── */
  // "Časové pásmo: UTC-4 (bez letního času)" or "UTC+5:30"
  const tzMatch = pageText.match(/[Čč]asov[eé]\s+p[aá]smo\s*:[^\n]*(UTC[+-]\d{1,2}(?::\d{2})?)/i);
  const timezoneRaw = tzMatch?.[1] ?? null;

  /* ── Extract socket types ──────────────────────────── */
  const socketRaw = pageText.match(/[Ee]lektrick[eé]\s+z[aá]suvk[ay]\s*:[^\n]*/i)?.[0] ?? '';
  const rawSocketTags = socketRaw.match(/[Tt]yp[u]?\s+([A-N](?:\/[A-N])*)/g) ?? [];
  const socketTypes = [...new Set(
    rawSocketTags.flatMap(m => m.replace(/^[Tt]yp[u]?\s+/, '').split('/'))
  )].filter(t => t in SOCKETS);

  /* ── Extract driving side ─────────────────────────── */
  const drivingMatch =
    pageText.match(/jezd[ií]\s+se\s+(vlevo|vpravo)/i) ??
    pageText.match(/j[ií]zda\s+(vlevo|vpravo)/i) ??
    pageText.match(/doprava\s+je\s+(?:veden[aá]\s+)?(?:po\s+)?(lev[eé]|prav[eé])\s+stran[eě]/i) ??
    pageText.match(/(levostrann[yý]|pravostrann[yý])\s+provoz/i);
  const drivingRaw = drivingMatch?.[1]?.toLowerCase() ?? null;
  const drivingSide = drivingRaw
    ? drivingRaw.startsWith('lev') || drivingRaw.startsWith('vle') || drivingRaw.includes('levostrann') ? 'vlevo' : 'vpravo'
    : null;

  const hasAnything = currencyCode || timezoneRaw || drivingSide || socketTypes.length > 0;
  if (!hasAnything) return;

  const bar = document.getElementById('dest-live');
  if (!bar) return;
  bar.style.display = 'flex';
  bar.classList.remove('hidden');

  /* ── 1. Exchange rate ──────────────────────────────── */
  if (currencyCode) {
    const wrap    = document.getElementById('live-currency-wrap');
    const codeEl  = document.getElementById('live-currency-code');
    const rateEl  = document.getElementById('live-exrate');
    if (wrap) { wrap.style.display = 'flex'; wrap.classList.remove('hidden'); }
    if (codeEl) codeEl.textContent = currencyCode;

    const preferredCurrencyKey = 'svet-za-malo:preferred-currency';
    const getPreferredCurrency = () => {
      try {
        return window.localStorage.getItem(preferredCurrencyKey) || 'CZK';
      } catch {
        return 'CZK';
      }
    };

    const renderRate = (targetCurrency: string) => {
      if (!rateEl) return;
      const target = targetCurrency.toUpperCase();

      if (target === currencyCode) {
        rateEl.textContent = '= místní měna';
        return;
      }

      rateEl.textContent = '…';
      fetch(`https://api.frankfurter.dev/v1/latest?base=${encodeURIComponent(currencyCode)}&symbols=${encodeURIComponent(target)}`)
        .then(r => r.ok ? r.json() : Promise.reject())
        .then((data: { rates?: Record<string, number> }) => {
          const rate = data?.rates?.[target];
          if (typeof rate === 'number') {
            rateEl.textContent = `≈ ${rate.toLocaleString('cs-CZ', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} ${target}`;
          }
        })
        .catch(() => {
          rateEl.textContent = '(kurz nedostupný)';
        });
    };

    renderRate(getPreferredCurrency());
    window.addEventListener('preferred-currency-change', (event) => {
      const currency = (event as CustomEvent<{ currency?: string }>).detail?.currency || 'CZK';
      renderRate(currency);
    });
  }

  /* ── 2. Live local time ────────────────────────────── */
  if (timezoneRaw) {
    const iana = resolveIANA(timezoneRaw);
    const wrap    = document.getElementById('live-clock-wrap');
    const sepTz   = document.getElementById('live-sep-tz');
    const clockEl = document.getElementById('live-clock');
    if (iana && clockEl) {
      if (wrap) { wrap.style.display = 'flex'; wrap.classList.remove('hidden'); }
      if (sepTz && currencyCode) {
        sepTz.style.display = 'inline'; sepTz.classList.remove('hidden');
      }
      const fmt = new Intl.DateTimeFormat('cs-CZ', {
        timeZone: iana, hour: '2-digit', minute: '2-digit', second: '2-digit',
      });
      const tick = () => { clockEl.textContent = fmt.format(new Date()); };
      tick();
      setInterval(tick, 1000);
    }
  }

  /* ── 3. Driving side ──────────────────────────────── */
  if (drivingSide) {
    const drivingEl = document.getElementById('live-driving');
    const drivingSideEl = document.getElementById('live-driving-side');
    const sepDriving = document.getElementById('live-sep-driving');

    if (drivingEl && drivingSideEl) {
      drivingEl.style.display = 'flex'; drivingEl.classList.remove('hidden');
      drivingSideEl.textContent = drivingSide;
      if (sepDriving && (currencyCode || timezoneRaw)) {
        sepDriving.style.display = 'inline'; sepDriving.classList.remove('hidden');
      }
    }
  }

  /* ── 4. Socket type badges ─────────────────────────── */
  if (socketTypes.length > 0) {
    const socketEl  = document.getElementById('live-socket');
    const sepSocket = document.getElementById('live-sep-socket');
    const tagsEl    = document.getElementById('live-socket-tags');
    if (!socketEl || !tagsEl) return;

    socketEl.style.display = 'flex'; socketEl.classList.remove('hidden');
    if (sepSocket && (currencyCode || timezoneRaw || drivingSide)) {
      sepSocket.style.display = 'inline'; sepSocket.classList.remove('hidden');
    }

    for (const type of socketTypes) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = `Typ ${type}`;
      btn.className =
        'rounded-md bg-primary-light px-2 py-0.5 text-xs font-semibold text-primary ' +
        'hover:bg-primary hover:text-white transition-colors select-none cursor-default';
      btn.dataset.socketType = type;
      tagsEl.appendChild(btn);
    }

    initSocketTooltip(tagsEl);
  }

  /* ── Socket tooltip ────────────────────────────────── */
  function initSocketTooltip(container: HTMLElement) {
    const tip      = document.getElementById('socket-tip') as HTMLElement | null;
    const tipSvg   = document.getElementById('socket-tip-svg') as SVGElement | null;
    const tipLabel = document.getElementById('socket-tip-label') as HTMLElement | null;
    if (!tip || !tipSvg || !tipLabel) return;

    let cursorX = 0, cursorY = 0;
    document.addEventListener('mousemove', e => { cursorX = e.clientX; cursorY = e.clientY; }, { passive: true });

    function positionTip() {
      const w = tip!.offsetWidth || 220, h = tip!.offsetHeight || 160;
      let x = cursorX + 14, y = cursorY - h - 14;
      if (x + w > window.innerWidth - 12) x = cursorX - w - 14;
      if (y < 8) y = cursorY + 16;
      tip!.style.left = `${x}px`;
      tip!.style.top  = `${y}px`;
    }

    container.addEventListener('mouseover', e => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-socket-type]');
      if (!btn) return;
      const def = SOCKETS[btn.dataset.socketType ?? ''];
      if (!def) return;
      tipSvg!.innerHTML = def.svgInner;
      tipLabel!.textContent = def.label;
      tip!.style.display = 'flex'; tip!.removeAttribute('aria-hidden');
      positionTip();
    });
    container.addEventListener('mousemove', positionTip);
    container.addEventListener('mouseout', e => {
      const related = (e as MouseEvent).relatedTarget as HTMLElement | null;
      if (related && container.contains(related)) return;
      tip!.style.display = 'none'; tip!.setAttribute('aria-hidden', 'true');
    });
  }

  /* ── Helpers ───────────────────────────────────────── */
  function resolveIANA(raw: string): string | null {
    const t = raw.trim();
    try { Intl.DateTimeFormat('en', { timeZone: t }); return t; } catch { /* not IANA */ }
    const m = t.match(/UTC([+-])(\d{1,2})(?::(\d{2}))?/i);
    if (!m) return null;
    const sign  = m[1] === '+' ? -1 : 1;
    const hours = parseInt(m[2], 10);
    const mins  = m[3] ? parseInt(m[3], 10) : 0;
    if (mins !== 0) return null;
    const offset = sign * hours;
    const tz = offset === 0 ? 'UTC' : `Etc/GMT${offset > 0 ? '+' : ''}${offset}`;
    try { Intl.DateTimeFormat('en', { timeZone: tz }); return tz; } catch { /* noop */ }
    return null;
  }
})();
</script>
