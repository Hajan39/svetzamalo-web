---
import { Image } from 'astro:assets';
import { translations } from '@/i18n/translations';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import type { Article } from '@/types';

interface Props {
  article: Article;
  variant?: 'default' | 'block' | 'compact';
}

const { article, variant = 'default' } = Astro.props;
const cover = article.coverImage;
const typeLabel = (article.articleType || 'destination-guide').replace(/-/g, ' ');
const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);
const readLabel = t('articleCard.read');
const dateLocale = translations[locale].shared.dateLocale;
---

{variant === 'block' ? (
  <a href={`/articles/${article.slug}`} class="group brand-card brand-card-hover block overflow-hidden">
    <div class="aspect-4/3 overflow-hidden rounded-t-lg bg-background-secondary">
      {cover ? (
        <Image src={cover.src} alt={cover.alt || article.title} width={600} height={450} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
      ) : (
        <div class="flex h-full w-full items-center justify-center bg-primary-light px-6 text-center text-sm font-semibold text-primary">{article.title}</div>
      )}
    </div>
    <div class="px-5 pb-5 pt-4 sm:px-6 sm:pb-6">
      <span class="inline-flex rounded-full bg-primary-light px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-primary">{typeLabel}</span>
      <h3 class="mt-3 text-base font-semibold text-foreground sm:text-lg">{article.title}</h3>
      <p class="article-card-intro mt-2 text-sm leading-relaxed text-foreground-secondary sm:text-base">{article.intro}</p>
      <span class="mt-4 inline-flex text-sm font-semibold text-primary">{readLabel}</span>
    </div>
  </a>
) : (
  <a href={`/articles/${article.slug}`} class="group brand-card brand-card-hover block p-6">
    <span class="inline-flex rounded-full bg-primary-light px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-primary">{typeLabel}</span>
    <h3 class="mt-4 text-lg font-semibold text-foreground transition-colors group-hover:text-primary">{article.title}</h3>
    <p class="article-card-intro mb-4 mt-2 text-sm text-foreground-secondary">{article.intro}</p>
    {article.publishedAt && <time class="text-xs text-foreground-muted" datetime={article.publishedAt}>{new Date(article.publishedAt).toLocaleDateString(dateLocale)}</time>}
  </a>
)}

<style>
  .article-card-intro {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }
</style>
