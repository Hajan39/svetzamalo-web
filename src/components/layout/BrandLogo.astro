---
import { Image } from "astro:assets";
import logoMark from "@/assets/logo-mark.png";

interface Props {
	size?: "default" | "header" | "footer";
	hideWordmarkOnMobile?: boolean;
	showWordmark?: boolean;
}

const {
	size = "default",
	hideWordmarkOnMobile = false,
	showWordmark = true,
} = Astro.props;

const markSizeClass =
	size === "header" ? "h-11 lg:h-12" : size === "footer" ? "h-12" : "sm:h-14";

const wordmarkVisibilityClass = hideWordmarkOnMobile
	? "hidden sm:flex"
	: "flex";
---

<span class="inline-flex items-center gap-3" role="img" aria-label="Svět za málo">
  <Image
    src={logoMark}
    alt="Logo"
    class:list={['h-auto w-auto object-contain', markSizeClass]}
    loading="eager"
    decoding="sync"
  />
  {showWordmark && (
    <span class:list={[wordmarkVisibilityClass, 'flex-col leading-none']}>
      <span class="font-brand text-[1.75rem] font-bold text-foreground sm:text-[2.05rem]">Svět za</span>
      <span class="font-brand -mt-1 text-[2rem] font-bold text-primary sm:text-[2.3rem]">málo</span>
    </span>
  )}
</span>
