---
interface Props {
  kicker?: string;
  title?: string;
  text?: string;
  source: string;
  leadType?: 'ebook' | 'newsletter' | 'book_notify';
  buttonLabel?: string;
  note?: string;
  compact?: boolean;
}

import { translations } from '@/i18n/translations';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);
const defaults = translations[locale].components.leadCapture;

const {
  kicker = defaults.kicker,
  title = defaults.title,
  text = defaults.text,
  source,
  leadType = 'ebook',
  buttonLabel = defaults.buttonLabel,
  note = defaults.note,
  compact = false,
} = Astro.props;
---

<section class:list={['lead-capture', compact ? 'lead-capture-compact' : '']}>
  <div>
    <p class="lead-kicker">{kicker}</p>
    <h2>{title}</h2>
    <p>{text}</p>
  </div>
  <form method="post" action="/api/leads" class="lead-form">
    <input type="hidden" name="leadType" value={leadType} />
    <input type="hidden" name="source" value={source} />
    <label class="sr-only" for={`lead-email-${source}`}>{t('leadCapture.emailLabel')}</label>
    <input id={`lead-email-${source}`} class="form-field" type="email" name="email" placeholder={t('leadCapture.emailPlaceholder')} autocomplete="email" required />
    <button class="btn-primary" type="submit">{buttonLabel}</button>
    <span class="lead-note">{note}</span>
  </form>
</section>
