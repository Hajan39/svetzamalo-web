    {
      "type": "paragraph",
      "children": [
        {
          "type": "text",
          "text": "Severně od Gamla stanu se nachází drobný ostrůvek na kterém naleznete budovy"
        },
        {
          "type": "text",
          "text": "parlamentu",
          "url": "https://goo.gl/maps/ivHXjUJ64WRY93C28",
          "bold": true
        },
        {
          "type": "text",
          "text": "a"
        },
        {
          "type": "text",
          "text": "Bezpečnostní",
          "bold": true
        },
        {
          "type": "text",
          "text": "rady státu",
          "url": "https://goo.gl/maps/QdwDp6zfLcwoZDDv7",
          "bold": true
        },
        {
          "type": "text",
          "text": ". Zbytek ostrova tvoří zelený hezky upravený park."
        }
      ]
    },
