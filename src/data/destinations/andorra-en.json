    {
      "type": "paragraph",
      "children": [
        {
          "type": "text",
          "text": "It is also worth mentioning the"
        },
        {
          "type": "text",
          "text": "Madriu River Valley",
          "bold": true
        },
        {
          "type": "text",
          "text": ", which is considered a UNESCO World Heritage site."
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
