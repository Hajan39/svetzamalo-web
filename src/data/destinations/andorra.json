    {
      "type": "image",
      "image": {
        "name": "20180927_174616-1024x768.jpg",
        "alternativeText": "V Andoře můžete vylézt téměř na každý kopec, kterých je zde nespočet. Pic de Palomer 2072 m n.m.",
