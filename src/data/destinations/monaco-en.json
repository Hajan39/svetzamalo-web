    {
      "type": "heading",
      "level": 3,
      "children": [
        {
          "type": "text",
          "text": "Casino",
          "url": "https://goo.gl/maps/1FbBugXvse9FwkUXA",
          "bold": true
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "type": "text",
          "text": "For approximately 10 euros, you can take a look inside the famous Casino in the Monte Carlo district. However, you can enter the entrance hall without paying the entrance fee after going through the security check."
        }
      ]
    },
