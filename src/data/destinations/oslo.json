		{
			"type": "heading",
			"level": 4,
			"children": [
				{
					"type": "text",
					"text": "Viking ship museum",
					"url": "https://goo.gl/maps/twJRDD8K9MSmZa6aA"
				}
			]
		},
		{
			"type": "paragraph",
			"children": [
				{
					"type": "text",
					"text": "Poměrně malé muzeum, kde naleznete několik dřevěných vikingských lodí a další předměty. Vstupné je zpoplatněné."
				}
			]
		},
