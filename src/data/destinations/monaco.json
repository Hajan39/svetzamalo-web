		},
		{
			"type": "heading",
			"level": 3,
			"children": [
				{
					"type": "text",
					"text": "Casino",
					"url": "https://goo.gl/maps/1FbBugXvse9FwkUXA",
					"bold": true
				}
			]
		},
		{
			"type": "paragraph",
			"children": [
				{
					"type": "text",
					"text": "Za zhruba 10 euro se můžete podívat dovnitř slavného Casina ve čtvrti Monte Carlo. Do vstupní haly se ovšem dostanete i bez placení vstupného, po bezpečnostní kontrole."
				}
			]
		},
