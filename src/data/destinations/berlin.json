		{
			"type": "heading",
			"level": 4,
			"children": [
				{
					"type": "text",
					"text": "Tiergarten",
					"url": "https://goo.gl/maps/3BEkUtvnQCB9Ab4XA"
				}
			]
		},
		{
			"type": "paragraph",
			"children": [
				{
					"type": "text",
					"text": "Jedná se o rozlehlý park navazující na Braniborskou bránu. Uvnitř parku naleznete několik památníků, soch, jezírek, fontán a také trochu klidu v centru města. Jedním z těch větších památníků je"
				},
				{
					"type": "text",
					"text": "Soviet war memorial",
					"url": "https://goo.gl/maps/79RwDawC3KcJdd4Z6",
					"bold": true
				},
				{
					"type": "text",
					"text": ", kde naleznete i několik tanků."
				}
			]
		},
