        {
          "type": "list-item",
          "children": [
            {
              "type": "text",
              "text": "Odpoledne: Souteski Vintgar (~5 EUR vstup) - drevene lavky nad rekou."
            }
          ]
        }
      ]
    },
    {
      "type": "heading",
      "level": 2,
      "children": [
        {
          "type": "text",
          "text": "Den 3: Bohinj + Savica"
