        },
        {
          "type": "list-item",
          "children": [
            {
              "type": "text",
              "text": "Lublansky hrad (lanovka nahoru, pesky dolu)."
            }
          ]
        },
        {
          "type": "list-item",
          "children": [
            {
              "type": "text",
              "text": "Vecere u reky Ljublanice - hipsterskedatvrti Metelkova."
            }
          ]
        }
      ]
    },
