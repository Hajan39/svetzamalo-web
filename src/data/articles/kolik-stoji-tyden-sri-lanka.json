        {
          "type": "list-item",
          "children": [
            {
              "type": "text",
              "text": "Jidlo: ~966 Kc/tyden (street food, lokalni podniky)"
            }
          ]
        },
        {
          "type": "list-item",
          "children": [
            {
              "type": "text",
              "text": "Doprava: ~644 Kc/tyden (MHD, skutr, sdilene taxi)"
