          ]
        },
        {
          "type": "list-item",
          "children": [
            {
              "type": "text",
              "text": "Jidlo: ~2009 Kc/tyden (restaurace, obcas street food)"
            }
          ]
        },
        {
          "type": "list-item",
          "children": [
            {
              "type": "text",
              "text": "Doprava: ~1610 Kc/tyden (taxi, pronajem skutru/auta)"
