      "level": 2,
      "children": [
        {
          "type": "text",
          "text": "Tyden ve stredni tride: ~8 050 Kc"
        }
      ]
    },
    {
      "type": "list",
      "format": "unordered",
      "children": [
        {
          "type": "list-item",
          "children": [
            {
              "type": "text",
              "text": "Ubytovani: ~3220 Kc/tyden (3* hotel, Airbnb)"
