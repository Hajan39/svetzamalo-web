        {
          "type": "list-item",
          "children": [
            {
              "type": "text",
              "text": "Z Bali je nejlevnější public ferry, který každý den vyjíždí z Padangbai a lístek koupíte přímo před odjezdem u přepážky v přístavu."
            }
          ]
        },
        {
          "type": "list-item",
          "children": [
            {
              "type": "text",
              "text": "Můžete se dostat na ceny kolem 50 tisíc rupií za den."
