# ============================================================================
# SVET ZA MALO WEB - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.local and fill in values for your environment.

# Site
VITE_SITE_URL=https://www.svetzamalo.cz

# Strapi
VITE_STRAPI_URL=http://localhost:1337
VITE_STRAPI_API_TOKEN=

# Analytics
VITE_ENABLE_ANALYTICS=false
VITE_ANALYTICS_PROVIDER=none
VITE_GA_TRACKING_ID=
VITE_GA_MEASUREMENT_ID=
VITE_SHOW_ANALYTICS_DEBUGGER=false

# Ads / monetization
VITE_ENABLE_ADS=false
VITE_AD_PROVIDER=none
VITE_ADSENSE_CLIENT_ID=

# Affiliate IDs used in code
VITE_SKYSCANNER_AFFILIATE_ID=
VITE_BOOKING_AFFILIATE_ID=
VITE_CJ_PID=
VITE_CJ_BOOKING_AID=

# Book feature
VITE_BOOK_AVAILABLE=false
VITE_BOOK_BUY_URL=
VITE_EBOOK_PDF_URL=
VITE_BOOK_PRICE=

# Optional
VITE_CDN_URL=

# Development
VITE_ENABLE_MOCK_DATA=false
VITE_LOG_LEVEL=info