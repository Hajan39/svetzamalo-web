# ============================================================================
# LOWCOST TRAVELING - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.local and fill in your actual values

# ============================================================================
# SITE CONFIGURATION
# ============================================================================
VITE_SITE_URL=https://lowcost-traveling.com

# ============================================================================
# ANALYTICS & TRACKING (GA4)
# ============================================================================
# Enable analytics (set to 'true' to enable)
VITE_ENABLE_ANALYTICS=true

# Analytics provider ('google-analytics', 'plausible', 'none')
VITE_ANALYTICS_PROVIDER=google-analytics

# Google Analytics 4
VITE_GA_TRACKING_ID=GA-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Alternative: Plausible Analytics (privacy-focused)
VITE_PLAUSIBLE_DOMAIN=yourdomain.com

# Debug analytics in development
VITE_SHOW_ANALYTICS_DEBUGGER=true

# ============================================================================
# MONETIZATION & ADS
# ============================================================================
# Enable ads (set to 'true' to enable)
VITE_ENABLE_ADS=true

# Ad provider ('adsense', 'none')
VITE_AD_PROVIDER=adsense

# Google AdSense
VITE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Affiliate partners
VITE_SKYSCANNER_AFFILIATE_ID=your_skyscanner_id
VITE_BOOKING_AFFILIATE_ID=your_booking_id

# ============================================================================
# STRAPI CMS
# ============================================================================
# Strapi API URL (default: http://localhost:1337)
VITE_STRAPI_URL=http://localhost:1337

# Strapi API Token (optional, for protected endpoints)
# Generate in Strapi Admin: Settings > API Tokens
VITE_STRAPI_API_TOKEN=your_strapi_api_token

# Force all content to stay static even when Strapi URL exists
VITE_USE_STATIC_CONTENT=false

# Current recommended split:
# - destinations from local JSON
# - articles from Strapi
VITE_USE_STATIC_DESTINATIONS=true
VITE_USE_STATIC_ARTICLES=false

# ============================================================================
# BOOK / EBOOK (behind feature flag)
# ============================================================================
VITE_BOOK_AVAILABLE=false
VITE_BOOK_BUY_URL=
VITE_EBOOK_PDF_URL=
VITE_BOOK_PRICE=

# ============================================================================
# DEVELOPMENT
# ============================================================================
# Enable mock data for development
VITE_ENABLE_MOCK_DATA=false

# Logging level ('error', 'warn', 'info', 'debug')
VITE_LOG_LEVEL=info

# ============================================================================
# DEPLOYMENT
# ============================================================================
# Vercel-specific
VERCEL_URL=your-vercel-url.vercel.app
VERCEL_ENV=production

# ============================================================================
# SECURITY (Optional)
# ============================================================================
# API keys for external services
# VITE_API_KEY=your_api_key
# VITE_SECRET_KEY=your_secret_key